import pygame

from constants import WIDTH, HEIGHT, Screen, Clock, Running, Cell_width, Cell_height, X_size, O_size, X_width, \
    Line_width, Circle_width, Corrective_val_text_width_1, Corrective_val_text_height_1, Framerate, Size_font, Colors, \
    Cells_ammount, Caption, Board_size


# TODO: indication for what side is playing currently
# TODO: make an easy constant for the (num x num) size of the board, like 4x4

class TicTacToe:

    def __init__(self):

        pygame.init()

        self.WIDTH = WIDTH
        self.HEIGHT = HEIGHT

        self.screen = Screen
        pygame.display.set_caption(Caption)

        self.clock = Clock

        self.running = Running
        self.board_size = Board_size

        self.cell_width = Cell_width
        self.cell_height = Cell_height

        self.X_size = X_size
        self.O_size = O_size

        self.X_width = X_width
        self.line_width = Line_width
        self.circle_width = Circle_width

        # half the width and height of text
        self.corrective_val_text_width_1 = Corrective_val_text_width_1
        self.corrective_val_text_height_1 = Corrective_val_text_height_1

        self.font = pygame.font.SysFont(None, Size_font)
        self.Colors = Colors

        self.reset_game()

    def reset_game(self):

        self.is_game_over = False

        self.current_is_x = True

        self.board = [[None] * self.board_size for _ in range(self.board_size)]

    def game_over_won(self):

        text_surface = self.font.render(f"{'O' if self.current_is_x else 'X'} is winner", True,
                                        self.Colors.TEXT_COLOR.value)
        self.screen.blit(text_surface, (self.WIDTH // 2 - self.corrective_val_text_width_1,
                                        self.HEIGHT // 2 - self.corrective_val_text_height_1))
        self.is_game_over = True
        # TODO no reason for this return RED: done

    def Diagonals_check(self):
        boolean = True

        if self.board[0][0] == self.board[1][1] == self.board[2][2] is not None or self.board[0][2] == self.board[1][
            1] == \
                self.board[2][0] is not None:  # TODO change to is not none RED: done
            self.game_over_won()
            boolean = False

        return boolean

    def vertical_check(self):
        boolean = True
        if self.board[0][0] == self.board[1][0] == self.board[2][0] is not None or self.board[0][1] == self.board[1][
            1] == \
                self.board[2][1] is not None or self.board[0][2] == self.board[1][2] == self.board[2][2] is not None:
            self.game_over_won()
            boolean = False

        return boolean

    def horizontal_check(self):
        boolean = True
        for row in self.board:
            if row[0] == row[1] == row[2] is not None:
                self.game_over_won()
                boolean = False

        return boolean

    def game_over_draw(self):
        boolean = True
        cell_count = sum(cell is not None for row in self.board for cell in row)  # how would I know that

        if cell_count == Cells_ammount:
            text_surface = self.font.render("game over", True, Colors.TEXT_COLOR.value)
            self.screen.blit(text_surface, ((self.WIDTH / 2) - self.corrective_val_text_width_1,
                                            (self.HEIGHT / 2) - self.corrective_val_text_height_1))
            boolean = False

        return boolean

    def game_logic(self):

        if self.Diagonals_check() and self.vertical_check() and self.horizontal_check() and self.game_over_draw():
            pass

    def draw_grid(self):

        start_pos = self.cell_width
        for position in range(self.board_size - 1):
            pygame.draw.line(self.screen, Colors.LINE_COLOR.value, (start_pos,0), (start_pos,self.HEIGHT), self.line_width)
            start_pos += self.cell_width

        start_pos = self.cell_height
        for position in range(self.board_size - 1):
            pygame.draw.line(self.screen, Colors.LINE_COLOR.value, (0,start_pos), (self.WIDTH,start_pos), self.line_width)
            start_pos += self.cell_height

    def draw_x(self, center):
        x, y = center

        pygame.draw.line(self.screen, Colors.X_COLOR.value, (x - self.X_size, y - self.X_size),
                         (x + self.X_size, y + self.X_size),
                         self.X_width)
        pygame.draw.line(self.screen, Colors.X_COLOR.value, (x + self.X_size, y - self.X_size),
                         (x - self.X_size, y + self.X_size),
                         self.X_width)

    def draw_circle(self, center):
        pygame.draw.circle(self.screen, Colors.O_COLOR.value, center, self.O_size, self.circle_width)

    def get_cell_center(self, row, col):
        center_x = col * self.cell_width + self.cell_width // 2
        center_y = row * self.cell_height + self.cell_height // 2

        return (center_x, center_y)

    def handle_click(self, pos):
        x, y = pos

        col = x // self.cell_width
        row = y // self.cell_height

        if self.board[row][col] is None:  # TODO don't use early returns RED: done
            self.board[row][col] = f"{'X' if self.current_is_x else 'O'}"

            self.current_is_x = not self.current_is_x

    def draw_signs(self):
        for row in range(self.board_size):
            for col in range(self.board_size):

                value = self.board[row][col]

                if value is None:
                    continue

                center = self.get_cell_center(row, col)

                if value == "X":
                    self.draw_x(center)
                else:
                    self.draw_circle(center)

    def handle_events(self):
        for event in pygame.event.get():

            if event.type == pygame.QUIT:
                self.running = False

            if not self.is_game_over:
                if event.type == pygame.MOUSEBUTTONDOWN:
                    self.handle_click(event.pos)

            keys = pygame.key.get_pressed()
            if keys[pygame.K_q]:
                self.running = False
            if keys[pygame.K_r]:
                self.reset_game()

    def actions(self):
        self.screen.fill(Colors.BLACK.value)

        self.draw_grid()

        self.draw_signs()

        self.game_logic()

        pygame.display.flip()

    def run(self):
        while self.running:
            self.handle_events()

            self.actions()

            self.clock.tick(Framerate)

        pygame.quit()


game = TicTacToe()
game.run()
